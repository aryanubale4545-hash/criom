# Gemini API Configuration
# Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Backend Hosting & Environment Settings
# The URL where this applet is hosted.
APP_URL="MY_APP_URL"
# Application environment (e.g. development, production, test)
NODE_ENV="development"
# Set to true to retrieve credentials from Google Cloud Secret Manager instead of env vars
USE_SECRET_MANAGER="false"
# Flag to disable Vite Hot Module Replacement in dev settings
DISABLE_HMR="false"

# Google Cloud Platform (GCP) & BigQuery Settings
# The target Google Cloud Project ID
GCP_PROJECT_ID="mock-project-id"

# Firebase Admin SDK Configuration
# Stringified JSON object of the Firebase Service Account Key. Replace with actual JSON in production.
FIREBASE_SERVICE_ACCOUNT_KEY_JSON='{"type":"service_account","project_id":"mock-project-id","private_key":"-----BEGIN PRIVATE KEY-----\nMOCK\n-----END PRIVATE KEY-----\n","client_email":"mock@project.iam.gserviceaccount.com"}'

# Firebase Client SDK Configuration (Prefixed with VITE_ for Vite bundling)
VITE_FIREBASE_API_KEY="mock-api-key"
VITE_FIREBASE_AUTH_DOMAIN="mock-project-id.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="mock-project-id"
VITE_FIREBASE_STORAGE_BUCKET="mock-project-id.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="123456789"
VITE_FIREBASE_APP_ID="1:123456789:web:mockapp"
